# market-intel/.env.example
# Bu dosyayi .env olarak kopyala ve gercek degerlerle doldur.
# .env asla git'e commit edilmemeli.

# --- MySQL baglanti bilgileri (database/schema.sql'deki market_intel semasi) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=market_intel
DB_USER=market_intel_user
DB_PASSWORD=change_me

# --- Scraper davranis ayarlari ---
BATCH_SIZE=500
REQUEST_TIMEOUT=15
MAX_RETRIES=3
RATE_LIMIT_DELAY=1.5
MAX_WORKERS=8

# --- Gorsel indirme kok dizini (goreli veya mutlak yol) ---
IMAGES_DIR=images
